# VoteSathi — Environment Configuration
# Copy this file to .env and fill in your values

PORT=3000
ALLOWED_ORIGIN=http://localhost:3000

# Google Gemini API Key (get free at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key (restrict in Google Cloud Console by HTTP referrer)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase (optional — for auth and data persistence)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_PROJECT_ID=your_project_id_here
